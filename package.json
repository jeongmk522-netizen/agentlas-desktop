{
  "name": "agentlas-desktop",
  "version": "0.1.4",
  "description": "Agentlas Desktop — AI 에이전트의 런처 (Steam for AI agents). BYOC: 사용자 Claude/ChatGPT/Gemini 구독 그대로.",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/electron/main.js",
  "author": {
    "name": "Agentlas",
    "email": "appbridge@appbridge.co.kr"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeongmk522-netizen/agentlas-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/jeongmk522-netizen/agentlas-desktop/issues"
  },
  "homepage": "https://agentlas.cloud/desktop",
  "scripts": {
    "dev": "concurrently -k --success first -n NEXT,ELECTRON -c blue,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "cd renderer && next dev -p 3100",
    "dev:electron": "wait-on http://localhost:3100 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development ELECTRON_START_URL=http://localhost:3100 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "cd renderer && next build && node -e \"require('fs').cpSync('out','../dist/renderer',{recursive:true})\"",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/gen-cli-architecture.mjs",
    "gen:cli-arch": "node scripts/gen-cli-architecture.mjs",
    "prebuild:renderer": "node -e \"require('fs').rmSync('dist/renderer',{recursive:true,force:true})\"",
    "postinstall": "electron-rebuild --force",
    "package:mac": "bash scripts/package-mac.sh",
    "install:mac:stable": "bash scripts/install-stable-mac.sh",
    "dist:mac:unsigned": "npm run build && electron-builder --mac -c.mac.notarize=false -c.mac.identity=null",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "release:mac:verify": "node scripts/verify-mac-release.mjs --write-env",
    "release:mac:candidate": "node scripts/verify-mac-release.mjs --write-env --allow-unnotarized",
    "release:readiness": "node scripts/release-readiness.mjs",
    "release:csr": "bash scripts/create-apple-csr.sh",
    "release:p12": "bash scripts/create-p12-from-apple-cert.sh",
    "release:mac:publish": "node scripts/publish-mac-release.mjs",
    "release:web-env": "node scripts/apply-web-release-env.mjs",
    "qa:committee": "node scripts/committee-gate.mjs",
    "typecheck": "tsc -p electron/tsconfig.json --noEmit && cd renderer && tsc --noEmit",
    "lint": "next lint --dir renderer",
    "clean": "node -e \"['dist','out','release','renderer/.next','renderer/out'].forEach(d=>require('fs').rmSync(d,{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.3.0",
    "cross-spawn": "^7.0.6",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.7",
    "next": "^15.0.0",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
